# Copy to `.env` and update values locally.

# SQL Server
SA_PASSWORD=CHANGE_ME
DB_HOST=db
DB_PORT=1433
DB_HOST_PORT=1433
DB_NAME=CoffeShop
DB_USER=sa

# Web container settings
ASPNETCORE_ENVIRONMENT=Development
USE_HTTPS_REDIRECTION=false
RUN_MIGRATIONS_ON_STARTUP=true

# Host port to access the web app
WEB_PORT=8080

# Build-time proxy (used only during `docker build`)
# BUILD_HTTP_PROXY=http://your-proxy:port
# BUILD_HTTPS_PROXY=http://your-proxy:port
# BUILD_NO_PROXY=localhost,127.0.0.1,db
